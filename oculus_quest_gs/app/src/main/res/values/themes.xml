<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AndroidGs" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="Theme.AndroidGs.Starting" parent="Theme.SplashScreen">
